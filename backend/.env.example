# Configuration du serveur
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://votre_user:votre_password@votre_cluster.mongodb.net/dating-app?appName=dating-app

# JWT Secret
JWT_SECRET=votre_secret_jwt_super_securise_changez_moi

# Session Secret
SESSION_SECRET=votre_secret_session_super_securise_changez_moi

# Agent Orchestrateur IA — Gemini Frontend
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# OAuth Google
GOOGLE_CLIENT_ID=votre_google_client_id
GOOGLE_CLIENT_SECRET=votre_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# OAuth Facebook
FACEBOOK_APP_ID=votre_facebook_app_id
FACEBOOK_APP_SECRET=votre_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/auth/facebook/callback

# OAuth Apple
APPLE_CLIENT_ID=votre_apple_client_id
APPLE_TEAM_ID=votre_apple_team_id
APPLE_KEY_ID=votre_apple_key_id
APPLE_CALLBACK_URL=http://localhost:5000/auth/apple/callback

# Email Configuration (pour l'authentification par email)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre_email@gmail.com
EMAIL_PASSWORD=votre_mot_de_passe_application

# Frontend URL
FRONTEND_URL=http://localhost:3000

# ── Stripe (Phase 6 — Monétisation) ──────────────────────
# Clé secrète : Dashboard Stripe → Développeurs → Clés API → sk_test_xxx (dev) / sk_live_xxx (prod)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret webhook : stripe listen --forward-to localhost:5000/api/payments/webhook (dev)
# En prod : Dashboard Stripe → Développeurs → Webhooks → endpoint → Afficher le secret de signature
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Price IDs : Dashboard Stripe → Catalogue de produits → créer 4 produits one-time → copier price_xxx
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_POPULAR=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_MEGA=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Taux de conversion (définis librement) ────────────────
# GLOBO_TO_COIN_RATE : 1 Globo = N Pièces (défaut: 1)
GLOBO_TO_COIN_RATE=1
# MIN_WITHDRAWAL_GLOBOS : minimum pour demander un retrait en argent réel (défaut: 1000)
MIN_WITHDRAWAL_GLOBOS=1000
